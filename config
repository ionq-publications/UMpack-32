sub libNeedsRefresh {
    my $pair;
    foreach $pair (@libLinks) {
        my ( $src, $dst ) = @$pair;
        return 1 if ( !-e $dst );
        return 1 if ( !-l $dst );
        my $target = readlink($dst);
        return 1 if ( !defined $target || $target ne $src );
    }
    my %expected;
    foreach $pair (@libLinks) {
        $expected{ $pair->[1] } = 1;
    }
    opendir( LIBDIR, "$PWD/lib" ) || die "Can't read $PWD/lib";
    while ( defined( my $entry = readdir(LIBDIR) ) ) {
        next     if ( $entry eq "." || $entry eq ".." );
        return 1 if ( !exists $expected{"lib/$entry"} );
    }
    closedir(LIBDIR);
    return 0;
}

