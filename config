sub buildBinaries() {
    chomp( $PWD = `pwd` );
    if ( !-e "$PWD/bin" ) {
        print "\nCreating directory $PWD/bin ...\n";
        system "mkdir $PWD/bin" || die "Can't create $PWD/bin";
    }

    print "\nAll static binaries will be stored in $PWD/bin ...\n";

    chomp( $strip = `which strip` );
    $strip = "" if $strip =~ /not found/i;

    $compile = "$MAKE testS";

    chdir "ABKCommon";
    print "\nChecking static binary compilation: ";
    system "$MAKE -s numbitS";
    if ( -e "numbits.exeS" ) {
        print "SUCCESS!\n";
        unlink "numbits.exeS";
    }
    else {
        print "FAILED!\n";
        print "\nYou cannot compile true static binaries. Would you like\n";
        print "to compile pseudo-static binaries (system libraries\n";
        print "will be linked dynamically) instead? [Y,n] ";
        $_ = <>;
        die "\n *** Good bye\n" if (/n/i);
        $compile = "$MAKE testSPseudo";
        system "/bin/mkdir $PWD/lib/save"
          || die "Can't make directory to save shared libraries";
        system "/bin/mv -f $PWD/lib/*.so $PWD/lib/save/"
          || die "Can't move shared libraries";
    }
    chdir "$PWD";

    chomp( $OS = `uname` );
    if ( $OS eq "Linux" ) { $OS = "Lnx"; }
    $FMver      = `perl -n -e \"print /FMPart(\\d.*)/\" Versions`;
    $MLver      = `perl -n -e \"print /MLPart(\\d.*)/\" Versions`;
    $Capover    = `perl -n -e \"print /Capo(\\d.*)/\" Versions`;
    $Parquetver = `perl -n -e \"print /ParquetFP(\\d.*)/\" Versions`;

    if ( -e "$PWD/CongestionMaps" ) {
        print "\nCompiling CongestionMaps binary ...\n";
        chdir "CongestionMaps";
        system $compile;
        system
"mv -f CongestionMapsTest0.exeS* $PWD/bin/CongestionMaps-$OS$nbits.exe";
        system "$strip $PWD/bin/CongestionMaps-$OS$nbits.exe"
          unless $strip eq "";
        system "rm -f *.exeS*";
        chdir "$PWD";
    }

    if ( -e "$PWD/FMPart" ) {
        print "\nCompiling FMPart binary ...\n";
        chdir "FMPart";
        system $compile;
        system "mv -f FMPartTest3.exeS* $PWD/bin/FMPart-$FMver-$OS$nbits.exe";
        system "$strip $PWD/bin/FMPart-$FMver-$OS$nbits.exe"
          unless $strip eq "";
        system "rm -f *.exeS*";
        chdir "$PWD";
    }

    if ( -e "$PWD/MetaPlacer" ) {
        print "\nCompiling MetaPlacer binary ...\n";
        chdir "MetaPlacer";
        system $compile;
        system
"mv -f MetaPlacerTest0.exeS* $PWD/bin/MetaPl-Capo$Capover-$OS$nbits.exe";
        system "$strip $PWD/bin/MetaPl-Capo$Capover-$OS$nbits.exe"
          unless $strip eq "";
        system
"ln -s $PWD/bin/MetaPl-Capo$Capover-$OS$nbits.exe $PWD/bin/Rooster.exe";
        system
"ln -s $PWD/bin/MetaPl-Capo$Capover-$OS$nbits.exe $PWD/bin/Scampi.exe";
        system "rm -f *.exeS*";
        chdir "$PWD";
    }

    if ( -e "$PWD/MLPart" ) {
        print "\nCompiling MLPart binary ...\n";
        chdir "MLPart";
        system $compile;
        system "mv -f MLPartTest2.exeS* $PWD/bin/MLPart-$MLver-$OS$nbits.exe";
        system "$strip $PWD/bin/MLPart-$MLver-$OS$nbits.exe"
          unless $strip eq "";
        system "rm -f *.exeS*";
        chdir "$PWD";
    }

    if ( -e "$PWD/RBPlace" ) {
        print "\nCompiling RBPlace binaries ...\n";
        chdir "RBPlace";
        system $compile;
        system "mv -f RBPlaceTest1.exeS* $PWD/bin/WLCalc-$OS$nbits.exe";
        system "$strip $PWD/bin/WLCalc-$OS$nbits.exe" unless $strip eq "";
        system "mv -f RBPlaceTest2.exeS* $PWD/bin/LayoutGen-$OS$nbits.exe";
        system "$strip $PWD/bin/LayoutGen-$OS$nbits.exe" unless $strip eq "";
        system "mv -f RBPlaceTest4.exeS* $PWD/bin/PlaceUtil-$OS$nbits.exe";
        system "$strip $PWD/bin/PlaceUtil-$OS$nbits.exe" unless $strip eq "";
        system "rm -f *.exeS*";
        chdir "$PWD";
    }

    if ( -e "$PWD/RBPlFromDB" ) {
        print "\nCompiling RBPlFromDB binary ...\n";
        chdir "RBPlFromDB";
        system $compile;
        system
          "mv -f RBPlFromDBTest0.exeS* $PWD/bin/LDToBookConvert-$OS$nbits.exe";
        system "$strip $PWD/bin/LDToBookConvert-$OS$nbits.exe"
          unless $strip eq "";
        system "rm -f *.exeS*";
        chdir "$PWD";
    }

    if ( -e "$PWD/RowIroning" ) {
        print "\nCompiling RowIroning binary ...\n";
        chdir "RowIroning";
        system $compile;
        system "mv -f RowIroningTest1.exeS* $PWD/bin/RowIroning-$OS$nbits.exe";
        system "$strip $PWD/bin/RowIroning-$OS$nbits.exe" unless $strip eq "";
        system "rm -f *.exeS*";
        chdir "$PWD";
    }

    if ( -e "$PWD/ParquetFP" ) {
        print "\nCompiling Parquet binary ...\n";
        chdir "ParquetFP";
        system $compile;
        system "mv -f Parquet.exeS* $PWD/bin/Parquet-$Parquetver-$OS$nbits.exe";
        system "$strip $PWD/bin/Parquet-$Parquetver-$OS$nbits.exe"
          unless $strip eq "";
        system "rm -f *.exeS*";
        chdir "$PWD";
    }

    if ( -e "$PWD/lib/save" ) {
        system "mv -f $PWD/lib/save/*.so $PWD/lib"
          || die "Can't move shared libraries";
        system "rm -rf $PWD/lib/save/";
    }
}

