        if ( !-d "$PWD/lib" ) {
            die "\n$PWD/lib exists but is not a directory\n";
        }
        if ( libNeedsRefresh() ) {
            print
"\n The directory $PWD/lib contains stale or missing library links.\n";
            print
" Would you like to remove it and recreate it from scratch ? [Y/n] ";
            $_ = <>;
            if ( !/n/i ) {
                system( "rm", "-rf", "$PWD/lib" ) == 0
                  || die "Can't remove $PWD/lib";
            }
        }
    }

    if ( !-e "$PWD/lib" ) {
        print "\nCreating  directory  $PWD/lib ... ";
        system( "mkdir", "$PWD/lib" ) == 0 || die "Can't create $PWD/lib";
    }
}

sub linkLib {
    my ( $src, $dst ) = @_;
    if ( -l $dst ) {
        my $target = readlink($dst);
        return if defined $target && $target eq $src;
    }
    unlink $dst if ( -e $dst || -l $dst );
    symlink $src, $dst || die "Can't create symlink $dst -> $src";
}

