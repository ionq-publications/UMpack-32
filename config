    $MAKE =~ s/make/makeOpt/g;
    system
"perl -p -i -e \'s/-O3( $platfOpt)*/-O3 $platfOpt/; s/ -ffloat-store//g\' gnu-make-wrapper.sh */makeOpt-gnu */*/makeOpt-gnu";
    if ( $MAKE =~ /gnu/i ) {
        print
          "\n Would you like to build a regression-only version (recommended\n";
