          " with regression test accuracy (A production build can be made by\n";
        print
" rerunning this config script at another time and answering no to this\n";
        print " question) ? [y/N] ";
        $_ = <>;
        if (/y/i) {
            print
"\n Disabling compiler optimizations that may interfere with regression testing\n";
            print
" (adding -ffloat-store, removing -march=native)\n";
            # -march=native produces architecture-specific FP rounding that
            # diverges from the precomputed expected.out (e.g. tiny epsilon
            # penalties), so strip it for regression-only builds. -funroll-loops
            # is kept; it is a real optimization and does not affect regression.
            system
"perl -p -i -e \'s/-O3/-O3 -ffloat-store/; s/ -march=native//g\' gnu-make-wrapper.sh */makeOpt-gnu */*/makeOpt-gnu";
        }
        else {
            $buildBinDefault     = 1;
            $doRegressionDefault = 0;
            print
"\n Allowing compiler optimizations that may interfere with regression testing\n";
        }
    }
}

