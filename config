# The per-package make-gnu / makeOpt-gnu wrappers are now thin delegators to the
# shared gnu-make-wrapper.sh in the project root, which is where the real
# compiler/linker command line and its flags live. Build-tweak substitutions
# below must therefore also be applied to that shared script, or they silently
# do nothing (the delegators no longer contain "make", "-O3", "-ffloat-store",
# etc).
if ($gmake) {
    system "perl -p -i -e \'s/^make/gmake/g\' */make*gnu */*/make*gnu";
    system "perl -p -i -e \'s/exec make\\b/exec gmake/g\' gnu-make-wrapper.sh";
}
else {
    system "perl -p -i -e \'s/gmake/make/g\' */make*gnu */*/make*gnu";
    system "perl -p -i -e \'s/exec gmake\\b/exec make/g\' gnu-make-wrapper.sh";
}

system "perl -p -i -e \'s/\\s*-fomit-frame-pointer//g\' gnu-make-wrapper.sh */*make* */*/*make*";

sub ensureLibDir {
