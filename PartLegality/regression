DIFF=/usr/bin/diff
WC=/usr/bin/wc
PROG=./PartLegalityTest

if [ ! -e libPartLegality.so ] && [ ! -e libPartLegality.a ]; then
	echo "Warning: 'make lib' may be required to run tests after 'make clean'."
fi

rm -f seeds.* >/dev/null 2>&1

cp TESTS/seeds.in seeds.in

echo "------------  Running test 0a..." >new.out
echo Running test 0a...
"$PROG"0.exe -f TESTS/ibm01+.aux >>new.out 2>&1

echo "------------  Running test 0b..." >>new.out
echo Running test 0b...
"$PROG"0.exe -f TESTS/ibm01+8.aux >>new.out 2>&1

echo "------------  Running test 1a..." >>new.out
echo Running test 1a...
"$PROG"1.exe -f TESTS/ibm01+.aux >>new.out 2>&1

echo "------------  Running test 1b..." >>new.out
echo Running test 1b...
"$PROG"1.exe -f TESTS/ibm01+8.aux >>new.out 2>&1

echo "------------  Running test 2a..." >>new.out
echo Running test 2a...
"$PROG"2.exe -f TESTS/ibm01+.aux >>new.out 2>&1

echo "------------  Running test 2b..." >>new.out
echo Running test 2b...
"$PROG"2.exe -f TESTS/ibm01+8.aux >>new.out 2>&1

egrep -v "(Created|took|seeds.in|arning|sec|User|Platform|Memory)" new.out >newout.notime
egrep -v "(Created|took|seeds.in|arning|sec|User|Platform|Memory)" expected.out >expectedout.notime
"$DIFF" newout.notime expectedout.notime >diffs.notime

echo " "
echo Differences from precomputed results
"$WC" diffs.notime

rm -f seeds.* t1.* >/dev/null 2>&1
